{
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/google/(.*)", "destination": "/api/google" },
    { "source": "/api/user/(.*)", "destination": "/api/user" },
    { "source": "/api/callsheets/(.*)", "destination": "/api/callsheets" },
    { "source": "/api/invoices/(.*)", "destination": "/api/invoices" },
    { "source": "/api/expenses/(.*)", "destination": "/api/expenses" },
    { "source": "/api/odometer/(.*)", "destination": "/api/odometer" },
    { "source": "/api/climatiq/(.*)", "destination": "/api/external" },
    { "source": "/api/electricity-maps/(.*)", "destination": "/api/external" },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|assets/|sw\\.js$|workbox-.*\\.js$|manifest\\.webmanifest$|favicon\\.ico$|logo\\.svg$).*)",
      "destination": "/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "github": {
    "silent": false,
    "autoAlias": true
  }
}
